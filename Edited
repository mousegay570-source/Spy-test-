-- ============================================================
--  IMPROVED DECOMPILER FUNCTIONS
-- ============================================================
local function formatString(str)
    if not str then return '""' end
    return string.format("%q", str)
end

local function instanceToString(inst)
    if not inst or type(inst) ~= "userdata" then return "nil" end
    local ok, result = pcall(function()
        if inst:IsA("Instance") then
            return "game:GetService(\"" .. inst.ClassName .. "\")"
        end
        return "nil"
    end)
    if ok then return result else return "nil" end
end

local function valueToString(value, depth)
    depth = depth or 0
    if depth > 10 then return "..." end
    
    local t = type(value)
    if t == "nil" then return "nil"
    elseif t == "number" then return tostring(value)
    elseif t == "boolean" then return tostring(value)
    elseif t == "string" then return formatString(value)
    elseif t == "function" then return "function() end"
    elseif t == "table" then
        local result = "{"
        local count = 0
        for k, v in pairs(value) do
            count = count + 1
            if count > 50 then
                result = result .. "..."
                break
            end
            if type(k) == "string" and k:match("^[%a_][%w_]*$") then
                result = result .. k .. " = " .. valueToString(v, depth + 1) .. ", "
            else
                result = result .. "[" .. valueToString(k, depth + 1) .. "] = " .. valueToString(v, depth + 1) .. ", "
            end
        end
        result = result .. "}"
        return result
    elseif t == "userdata" then
        if typeof(value) == "Instance" then
            return "game:GetService(\"" .. value.ClassName .. "\")"
        end
        return "newproxy()"
    end
    return "nil"
end

local function generateScript(remote, args)
    local script = ""
    if #args > 0 then
        script = script .. "local args = " .. valueToString(args) .. "\n\n"
        if remote:IsA("RemoteEvent") then
            script = script .. "game:GetService(\"" .. remote.ClassName .. "\"):FireServer(unpack(args))"
        elseif remote:IsA("RemoteFunction") then
            script = script .. "game:GetService(\"" .. remote.ClassName .. "\"):InvokeServer(unpack(args))"
        end
    else
        if remote:IsA("RemoteEvent") then
            script = script .. "game:GetService(\"" .. remote.ClassName .. "\"):FireServer()"
        elseif remote:IsA("RemoteFunction") then
            script = script .. "game:GetService(\"" .. remote.ClassName .. "\"):InvokeServer()"
        end
    end
    return script
end

-- ============================================================
--  REMOTE LOGGING - FIX DUPLICATE
-- ============================================================
local lastRemoteLog = {}

local function newRemote(type, name, args, remote, blocked)
    -- Check for duplicate (same remote, same args within 0.5 second)
    local key = tostring(remote) .. ":" .. tostring(name) .. ":" .. HttpService:JSONEncode(args)
    local now = tick()
    if lastRemoteLog[key] and (now - lastRemoteLog[key] < 0.5) then
        return -- Skip duplicate
    end
    lastRemoteLog[key] = now
    
    -- Check name blocklist
    if nameBlocklist[name] then return end
    
    logCount = logCount + 1
    
    local displayName = string.sub(name, 1, 40)
    local typePrefix = (type == "event") and "📡 " or "⚡ "
    displayName = typePrefix .. "[" .. logCount .. "] " .. displayName
    
    -- Create log entry
    local remoteFrame = Instance.new("Frame")
    remoteFrame.Parent = LogList
    remoteFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
    remoteFrame.BackgroundTransparency = 0.3
    remoteFrame.Size = UDim2.new(0, 150, 0, 24)
    remoteFrame.LayoutOrder = 999999999 - logCount
    
    local frameCorner = Instance.new("UICorner")
    frameCorner.CornerRadius = UDim.new(0, 6)
    frameCorner.Parent = remoteFrame
    
    local colorBar = Instance.new("Frame")
    colorBar.Parent = remoteFrame
    colorBar.BackgroundColor3 = (type == "event") and Color3.fromRGB(255, 200, 50) or Color3.fromRGB(100, 150, 255)
    colorBar.BorderSizePixel = 0
    colorBar.Position = UDim2.new(0, 0, 0, 2)
    colorBar.Size = UDim2.new(0, 4, 0, 20)
    
    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(0, 4)
    barCorner.Parent = colorBar
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Parent = remoteFrame
    textLabel.BackgroundTransparency = 1
    textLabel.Position = UDim2.new(0, 8, 0, 0)
    textLabel.Size = UDim2.new(1, -8, 0, 24)
    textLabel.Font = Enum.Font.Gotham
    textLabel.Text = displayName
    textLabel.TextColor3 = Color3.fromRGB(220, 220, 240)
    textLabel.TextSize = 10
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.TextTruncate = Enum.TextTruncate.AtEnd
    
    local btn = Instance.new("TextButton")
    btn.Parent = remoteFrame
    btn.BackgroundTransparency = 1
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = ""
    btn.ZIndex = 2
    
    local logData = {
        Name = name,
        Type = type,
        Number = logCount,
        Remote = remote,
        Args = args,
        Blocked = blocked,
        Log = remoteFrame,
        GenScript = generateScript(remote, args)
    }
    
    table.insert(logs, logData)
    
    btn.MouseButton1Click:Connect(function()
        selectRemote(logData)
    end)
    
    updateRemoteCanvas()
end

function selectRemote(logData)
    if selected then
        if selected.Log and selected.Log.BackgroundColor3 then
            selected.Log.BackgroundColor3 = Color3.fromRGB(30, 30, 50)
        end
    end
    selected = logData
    if selected and selected.Log then
        selected.Log.BackgroundColor3 = Color3.fromRGB(50, 50, 80)
        codebox:setRaw(selected.GenScript or "-- No script generated")
        BPStatus.Text = "Selected: " .. tostring(selected.Name)
        BPStatus.TextColor3 = Color3.fromRGB(200, 200, 100)
    end
end

function updateRemoteCanvas()
    LogList.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y + 10)
    LogList.CanvasPosition = Vector2.new(0, 0)
end

-- ============================================================
--  HOOKING SYSTEM - FIX BUGS
-- ============================================================
local originalFireServer = nil
local originalInvokeServer = nil
local remoteEvent = Instance.new("RemoteEvent")
local remoteFunction = Instance.new("RemoteFunction")

local function toggleSpy()
    toggle = not toggle
    
    if toggle then
        -- Hook RemoteEvent.FireServer
        pcall(function()
            originalFireServer = hookfunction(remoteEvent.FireServer, function(remote, ...)
                local args = {...}
                task.spawn(function()
                    newRemote("event", remote.Name, args, remote, false)
                end)
                return originalFireServer(remote, ...)
            end)
        end)
        
        -- Hook RemoteFunction.InvokeServer
        pcall(function()
            originalInvokeServer = hookfunction(remoteFunction.InvokeServer, function(remote, ...)
                local args = {...}
                task.spawn(function()
                    newRemote("function", remote.Name, args, remote, false)
                end)
                return originalInvokeServer(remote, ...)
            end)
        end)
        
        TitleBtn.Text = "✦ SimpleSpy v2 [ACTIVE]"
        TitleBtn.TextColor3 = Color3.fromRGB(100, 255, 150)
    else
        -- Unhook
        pcall(function()
            if originalFireServer then
                hookfunction(remoteEvent.FireServer, originalFireServer)
            end
        end)
        pcall(function()
            if originalInvokeServer then
                hookfunction(remoteFunction.InvokeServer, originalInvokeServer)
            end
        end)
        
        TitleBtn.Text = "✦ SimpleSpy v2 [INACTIVE]"
        TitleBtn.TextColor3 = Color3.fromRGB(180, 200, 255)
    end
end

